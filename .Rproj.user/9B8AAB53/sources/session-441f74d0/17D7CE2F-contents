# =============================================================================
# 3. PANEL DATA SETUP
# =============================================================================

pdata <- pdata.frame(df1, index = c("country", "year"))

# Log-transform q0 for better distributional properties (logit also fine)
pdata$logit_qx <- log(pdata$q0 / (1 - pdata$q0))   # logit scale

# =============================================================================
# 4. FIXED EFFECTS (WITHIN) MODEL – two-way FE (country + year)
# =============================================================================

# Model 1: grandmothers only
fe1 <- plm(logit_qx ~ gm,
           data = pdata, model = "within", effect = "twoways")

# Model 2: + siblings
fe2 <- plm(logit_qx ~ gm + os,
           data = pdata, model = "within", effect = "twoways")

# Model 3: + mean age of mother (full model)
fe3 <- plm(logit_qx ~ gm + os + age_m,
           data = pdata, model = "within", effect = "twoways")

# Clustered standard errors (by country)
cl_se <- function(model) coeftest(model, vcov = vcovHC(model, type = "HC1", cluster = "group"))

cat("\n=== Fixed Effects Model 1 (grandmothers only) ===\n"); print(cl_se(fe1))
cat("\n=== Fixed Effects Model 2 (+ os) ===\n");        print(cl_se(fe2))
cat("\n=== Fixed Effects Model 3 (full) ===\n");              print(cl_se(fe3))

# Regression table (saved to file)
modelsummary(
  list("GM only" = fe1, "+ os" = fe2, "Full" = fe3),
  vcov = list(
    ~country, ~country, ~country   # cluster by country
  ),
  stars = TRUE,
  gof_omit = "IC|Log|F$",
  title = "Two-Way Fixed Effects Models: Logit(Infant Mortality)",
  output = "fe_table.html"
)
cat("Saved: fe_table.html\n")

# =============================================================================
# 5. RANDOM EFFECTS & HAUSMAN TEST
# =============================================================================

re3 <- plm(logit_qx ~ gm + os + age_m,
           data = pdata, model = "random")

cat("\n=== Hausman Test (FE vs RE) ===\n")
hausman <- phtest(fe3, re3)
print(hausman)
cat(
  "\nInterpretation: p =", round(hausman$p.value, 4),
  "->", ifelse(hausman$p.value < 0.05,
               "Reject RE; use Fixed Effects (endogeneity present).",
               "Fail to reject RE; Random Effects may be preferred."), "\n"
)

# =============================================================================
# 6. GRANGER CAUSALITY (country-by-country VAR)
# =============================================================================
# Tests whether lagged grandmothers predict infant mortality
# beyond its own lags (and vice versa).

cat("\n=== Granger Causality Tests (by country) ===\n\n")

granger_results <- map_dfr(countries, function(ctry) {
  sub <- df %>% filter(country == ctry) %>%
    arrange(year) %>%
    select(logit_qx = q0, gm) %>%
    mutate(logit_qx = log(logit_qx / (1 - logit_qx)))

  # Choose lag order by AIC (up to 5)
  vselect <- VARselect(sub, lag.max = 5, type = "const")
  best_lag <- max(1, vselect$selection["AIC(n)"])

  var_fit <- VAR(sub, p = best_lag, type = "const")

  # Does grandmothers Granger-cause logit_q0?
  gc_gm_to_q0 <- causality(var_fit, cause = "grandmothers")$Granger
  # Does logit_q0 Granger-cause grandmothers?
  gc_q0_to_gm <- causality(var_fit, cause = "logit_q0")$Granger

  tibble(
    country       = ctry,
    lag_selected  = best_lag,
    `GM → q0 F`   = round(gc_gm_to_q0$statistic, 3),
    `GM → q0 p`   = round(gc_gm_to_q0$p.value, 4),
    `q0 → GM F`   = round(gc_q0_to_gm$statistic, 3),
    `q0 → GM p`   = round(gc_q0_to_gm$p.value, 4)
  )
})

print(granger_results)
write_csv(granger_results, "granger_results.csv")
cat("Saved: granger_results.csv\n")

cat("\nNote: 'GM → q0' tests whether grandmothers Granger-cause infant mortality.\n")
cat("p < 0.05 supports a predictive (causal) role for grandmothers.\n")

# =============================================================================
# 7. VISUALISE FIXED EFFECTS RESULTS
# =============================================================================

# 7a. Coefficient plot for full FE model (with clustered SEs)
coef_df <- tidy(cl_se(fe3)) %>%
  filter(term != "(Intercept)") %>%
  mutate(
    term = recode(term,
                  grandmothers    = "Grandmothers",
                  siblings        = "Siblings",
                  mean_age_mother = "Mean Age of Mother"),
    ci_lo = estimate - 1.96 * std.error,
    ci_hi = estimate + 1.96 * std.error
  )

p_coef <- ggplot(coef_df, aes(estimate, reorder(term, estimate))) +
  geom_vline(xintercept = 0, linetype = "dashed", colour = "grey50") +
  geom_errorbarh(aes(xmin = ci_lo, xmax = ci_hi), height = 0.2, colour = "#2c7bb6") +
  geom_point(size = 3, colour = "#2c7bb6") +
  labs(title = "Fixed Effects Estimates (Full Model)",
       subtitle = "Outcome: Logit(Infant Mortality) | Clustered SEs by Country",
       x = "Coefficient Estimate", y = NULL) +
  theme(plot.subtitle = element_text(size = 10, colour = "grey40"))

# 7b. Granger p-value plot
p_granger <- granger_results %>%
  select(country, `GM → q0 p`, `q0 → GM p`) %>%
  pivot_longer(-country, names_to = "direction", values_to = "pvalue") %>%
  mutate(direction = recode(direction,
                            `GM → q0 p` = "Grandmothers → Mortality",
                            `q0 → GM p` = "Mortality → Grandmothers")) %>%
  ggplot(aes(country, pvalue, fill = direction)) +
  geom_col(position = "dodge") +
  geom_hline(yintercept = 0.05, linetype = "dashed", colour = "red") +
  annotate("text", x = 0.6, y = 0.06, label = "p = 0.05", colour = "red", size = 3) +
  scale_fill_manual(values = c("#2c7bb6", "#d7191c")) +
  labs(title = "Granger Causality p-values by Country",
       x = NULL, y = "p-value", fill = "Direction") +
  theme(legend.position = "bottom")

results_plot <- p_coef / p_granger +
  plot_annotation(title = "Model Results: Grandmother Effect on Infant Mortality",
                  theme = theme(plot.title = element_text(face = "bold", size = 14)))

print(results_plot)
ggsave("results_plots.png", results_plot, width = 10, height = 9, dpi = 150)
cat("Saved: results_plots.png\n")

