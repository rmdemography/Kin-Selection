# 8. WITHIN-COUNTRY DEMEANED SCATTER (FE intuition)
# =============================================================================

df_demeaned <- df %>%
  group_by(country) %>%
  mutate(
    logit_q0    = log(q0 / (1 - q0)),
    dm_q0       = logit_q0 - mean(logit_q0),
    dm_gm       = grandmothers - mean(grandmothers)
  ) %>%
  ungroup()

p_within <- ggplot(df_demeaned, aes(dm_gm, dm_q0, colour = country)) +
  geom_point(alpha = 0.5, size = 1.5) +
  geom_smooth(method = "lm", se = FALSE, linewidth = 0.9) +
  geom_smooth(aes(group = 1), method = "lm", se = TRUE,
              colour = "black", linewidth = 1.1, linetype = "dashed") +
  labs(title = "Within-Country (Demeaned) Relationship",
       subtitle = "Logit(q0) vs Grandmothers, after removing country means",
       x = "Grandmothers (demeaned)", y = "Logit(q0) (demeaned)", colour = NULL) +
  theme(plot.subtitle = element_text(size = 10, colour = "grey40"))

print(p_within)
