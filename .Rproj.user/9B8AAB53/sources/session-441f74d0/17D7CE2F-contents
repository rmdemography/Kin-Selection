# =============================================================================
# 1. LOAD DATA
# =============================================================================
# Replace this block with your actual data import, e.g.:
#   df <- read_csv("your_data.csv")
#
# Expected columns:
#   country  – country identifier (character or factor)
#   year     – integer year (1950–2023)
#   q0       – probability of infant death (0–1)
#   grandmothers – expected number of living grandmothers
#   siblings     – expected number of siblings
#   mean_age_mother – mean age of mothers at birth

# ----- SYNTHETIC EXAMPLE DATA (replace with your own) -----------------------
set.seed(42)
years   <- 1950:2023
countries <- c("Country_A", "Country_B", "Country_C")

make_country <- function(country, base_q0, base_gm, trend_q0, trend_gm, noise_sd = 0.003) {
  n <- length(years)
  t <- seq_len(n)
  gm  <- base_gm + trend_gm * t + rnorm(n, 0, 0.05)
  sib <- 4 - 0.03 * t + rnorm(n, 0, 0.2)
  mam <- 26 + 0.04 * t + rnorm(n, 0, 0.5)
  # Grandmother effect: more grandmothers -> lower infant mortality
  q0  <- base_q0 + trend_q0 * t - 0.012 * gm + 0.005 * sib + rnorm(n, 0, noise_sd)
  q0  <- pmax(pmin(q0, 0.30), 0.002)   # keep in (0,1)
  tibble(country, year = years, q0, grandmothers = gm, siblings = sib,
         mean_age_mother = mam)
}

df <- bind_rows(
  make_country("Country_A", 0.15, 0.8, -0.0018, 0.010),
  make_country("Country_B", 0.12, 1.0, -0.0015, 0.008),
  make_country("Country_C", 0.18, 0.6, -0.0020, 0.012)
)
