# Grandmother Effect on Infant Mortality: Panel Data Analysis
# Data: 3 countries, 1950–2023 (country-year panel)
# =============================================================================

# --- 0. Install & load packages ----------------------------------------------

packages <- c("tidyverse", "plm", "lmtest", "sandwich", "vars",
